# Database
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASS=root
DB_NAME=school_db

# SMTP (fill these to send real emails)
# Example (SendGrid SMTP):
# SMTP_HOST=smtp.sendgrid.net
# SMTP_PORT=587
# SMTP_USER=apikey    # for SendGrid use 'apikey' as user and your API key as password
# SMTP_PASS=YOUR_SENDGRID_API_KEY

# Or Gmail SMTP (less recommended; use App Passwords):
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-app-password

# Admin email to receive inbound enquiry notifications
ADMIN_EMAIL=admissions@yourdomain.com

# Optional: override base URL for frontend/api if needed
# VITE_API_BASE_URL=http://localhost:5000/api
